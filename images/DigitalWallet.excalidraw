      "isDeleted": false,
      "boundElements": null,
      "updated": 1782974749163,
      "link": null,
      "locked": false,
      "text": "APIs\nPOST /api/v1/onboarding/applications ( idempotency key)\nevent onboarding-completed\nwallet-created\n\n\n\nPOST /api/v1/payments/deposits ( idempotency key)\n\n\nPOST /api/v1/webhook/deposits\nevent money-deposited\n\nPOST /apiv1/webhook/cards\n\n\n\nPOST /api/v1/payments/transfers\n\n\nmake-transfer.v1\ndebit-wallet.v1\ncredit-wallet.v1\nwallet-debited.v1\nwallet.credited.v1\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "APIs\nPOST /api/v1/onboarding/applications ( idempotency key)\nevent onboarding-completed\nwallet-created\n\n\n\nPOST /api/v1/payments/deposits ( idempotency key)\n\n\nPOST /api/v1/webhook/deposits\nevent money-deposited\n\nPOST /apiv1/webhook/cards\n\n\n\nPOST /api/v1/payments/transfers\n\n\nmake-transfer.v1\ndebit-wallet.v1\ncredit-wallet.v1\nwallet-debited.v1\nwallet.credited.v1\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
