    {
      "id": "z6EDpyogmMsdLryPnoRHm",
      "type": "text",
      "x": 596,
      "y": 140.5,
      "width": 214.83984375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
