    {
      "id": "jg5rtS5-PyTpFv2d8ueoO",
      "type": "text",
      "x": 1046.2286071777344,
      "y": 2173.885223388672,
      "width": 782.0195922851562,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
