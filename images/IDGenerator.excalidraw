      "roundness": null,
      "seed": 149183322,
      "version": 284,
      "versionNonce": 2055286790,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1781360877818,
      "link": null,
      "locked": false,
      "text": "INCR : inreaments user123 value by 1 ( if no key found redis will create teh key)\nEXPIRE : Expire user123 after 60 seconds ( TTL)\nSet EXPIRE after the first operation i.e create",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "INCR : inreaments user123 value by 1 ( if no key found redis will create teh key)\nEXPIRE : Expire user123 after 60 seconds ( TTL)\nSet EXPIRE after the first operation i.e create",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Q2mwGM2VErtHHWUw3beAJ",
      "type": "text",
      "x": 621.3156435187819,
      "y": 2302.2577282069738,
      "width": 539.3795776367188,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2k",
      "roundness": null,
      "seed": 1472056218,
      "version": 228,
      "versionNonce": 1299069786,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1781360877818,
      "link": null,
      "locked": false,
      "text": "Redis solves problems like,\n1. Fault tolerance\n2. synchronization between multiple servers\n3. Race conditions between calls from different servers\n4. We can add repliation to avid SPOF for redis\n\nMULTI ( like transaction)\nINCR user:123\nEXPIRE user:123 60\nEXEC",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Redis solves problems like,\n1. Fault tolerance\n2. synchronization between multiple servers\n3. Race conditions between calls from different servers\n4. We can add repliation to avid SPOF for redis\n\nMULTI ( like transaction)\nINCR user:123\nEXPIRE user:123 60\nEXEC",
      "autoResize": true,
      "lineHeight": 1.25
    },
