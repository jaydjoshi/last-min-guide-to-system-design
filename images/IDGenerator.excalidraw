    {
      "id": "wCzFbDKiH5byl4mseEUpS",
      "type": "text",
      "x": 555,
      "y": 1631.5,
      "width": 368.23968505859375,
      "height": 525,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
