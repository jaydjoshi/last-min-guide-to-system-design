    },
    {
      "id": "pKQEsb7o8ctJHxF9p3dcQ",
      "type": "text",
      "x": 579.9972229003906,
      "y": 1444.0222778320312,
      "width": 863.0393676757812,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "as",
      "roundness": null,
      "seed": 240623825,
      "version": 867,
      "versionNonce": 1584582559,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1781340131039,
      "link": null,
      "locked": false,
      "text": "Types:\n1. In memory cache : \n2. Distributed cache : Redis\n\nCaching strategies:\na. Reads\n    - Cache aside : \n        Cache hit : read from cache\n        Cache miss : Service reads from DB and stores in cache \n    - Cache through :\n        Cache hit : read from cache\n        cache miss : Service reads from Cache and cache reads from DB, persists in cache\nb. Writes\n    - Write through : \n        Service writes to cache and cache writes to DB\n    - Write Around :\n        Service writes to DB and when read from cache, cache reads from DB and writes\n    - Write Back :\n        Service writes to cache, cache async flushes to DB    \n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Types:\n1. In memory cache : \n2. Distributed cache : Redis\n\nCaching strategies:\na. Reads\n    - Cache aside : \n        Cache hit : read from cache\n        Cache miss : Service reads from DB and stores in cache \n    - Cache through :\n        Cache hit : read from cache\n        cache miss : Service reads from Cache and cache reads from DB, persists in cache\nb. Writes\n    - Write through : \n        Service writes to cache and cache writes to DB\n    - Write Around :\n        Service writes to DB and when read from cache, cache reads from DB and writes\n    - Write Back :\n        Service writes to cache, cache async flushes to DB    \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
