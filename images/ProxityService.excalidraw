    {
      "id": "rvbpmfl9Cmk7LlahsHM-8",
      "type": "text",
      "x": 3181.9362295247074,
      "y": 766.9107184963856,
      "width": 490.33551025390625,
      "height": 460,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bcd",
      "roundness": null,
      "seed": 491166028,
      "version": 585,
      "versionNonce": 494284020,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783235518371,
      "link": null,
      "locked": false,
      "text": "We iterate will we get less than 100 businessnes in a leaf node\n\nEach leaf node :\nmeta data : 10 bytes\nlat and long of nw and se quads : 32 bytes\n100 busineses with ids: 8 bytes\n800 + 32 bytes per leaf\n\n100 m businesses/ 100\n= 1 m leaf \n= 832 b * 10^6\n= 832 mb\n\ninternal nodes\n4 * clilds pointer = 32 bytes\nlat and long of nw and se quads : 32 bytes\n64 bytes\n1m * 1/3 = 0.33m\n= 32 bytes * 0.33 * 10^6\n= 11 mb\n= 850 mb of data for quadtree\n\nsmall to fit in mememory",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We iterate will we get less than 100 businessnes in a leaf node\n\nEach leaf node :\nmeta data : 10 bytes\nlat and long of nw and se quads : 32 bytes\n100 busineses with ids: 8 bytes\n800 + 32 bytes per leaf\n\n100 m businesses/ 100\n= 1 m leaf \n= 832 b * 10^6\n= 832 mb\n\ninternal nodes\n4 * clilds pointer = 32 bytes\nlat and long of nw and se quads : 32 bytes\n64 bytes\n1m * 1/3 = 0.33m\n= 32 bytes * 0.33 * 10^6\n= 11 mb\n= 850 mb of data for quadtree\n\nsmall to fit in mememory",
      "autoResize": true,
      "lineHeight": 1.25
    },
