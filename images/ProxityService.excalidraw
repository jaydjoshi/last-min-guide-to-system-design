    {
      "id": "Xk-t7OozrP1QOkxVkJnpR",
      "type": "text",
      "x": 1008.9781799316406,
      "y": 919.697265625,
      "width": 584.7195434570312,
      "height": 375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
