      "index": "b1x",
      "roundness": null,
      "seed": 474506423,
      "version": 3,
      "versionNonce": 1151460087,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1781491138701,
      "link": null,
      "locked": false,
      "text": "Write arrives\n      │\n      ▼\nVector Clock / LWW\nDetermine version ordering\n      │\n      ▼\nQuorum Write\nStore on replicas\n      │\n      ▼\nSloppy Quorum\nUsed if owners unavailable\n      │\n      ▼\nHinted Handoff\nReturns misplaced data later\n      │\n      ▼\nGossip Protocol\nNodes learn cluster state\n      │\n      ▼\nRead Repair\nFixes data discovered during reads\n      │\n      ▼\nAnti-Entropy Repair\nBackground synchronization\n      │\n      ▼\nMerkle Trees\nEfficiently locate differences",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Write arrives\n      │\n      ▼\nVector Clock / LWW\nDetermine version ordering\n      │\n      ▼\nQuorum Write\nStore on replicas\n      │\n      ▼\nSloppy Quorum\nUsed if owners unavailable\n      │\n      ▼\nHinted Handoff\nReturns misplaced data later\n      │\n      ▼\nGossip Protocol\nNodes learn cluster state\n      │\n      ▼\nRead Repair\nFixes data discovered during reads\n      │\n      ▼\nAnti-Entropy Repair\nBackground synchronization\n      │\n      ▼\nMerkle Trees\nEfficiently locate differences",
      "autoResize": true,
      "lineHeight": 1.25
    }
