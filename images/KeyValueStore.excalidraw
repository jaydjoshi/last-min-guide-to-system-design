    {
      "id": "vDKspD1mPgRqm1KnU7SAQ",
      "type": "text",
      "x": -251.96390840604897,
      "y": 2216.296859185985,
      "width": 342.8197021484375,
      "height": 825,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
