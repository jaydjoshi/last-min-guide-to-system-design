      "locked": false,
      "text": "Read Repair:\nQuestion:\nCan reads help fix inconsistencies?\nYes.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Read Repair:\nQuestion:\nCan reads help fix inconsistencies?\nYes.",
