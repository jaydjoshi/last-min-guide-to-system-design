      "isDeleted": false,
      "boundElements": null,
      "updated": 1781414562477,
      "link": null,
      "locked": false,
      "text": "Partition\nPartition keys by hash, key ranges\nif by hash use Consistent hashing\nand replicate to next n nodes",
