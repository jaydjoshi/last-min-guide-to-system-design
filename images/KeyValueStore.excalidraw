    {
      "id": "vdYZ07dzcjxwR5KD4Dg0d",
      "type": "text",
      "x": 545.5461645377895,
      "y": 3953.083038312659,
      "width": 336.439697265625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
