      "version": 208,
      "versionNonce": 51481138,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783006000260,
      "link": null,
      "locked": false,
      "text": "Reporting flow\n1. Order manager stores\n    order entry\n    order status\n    client id\n2. this data is later used for reconciliation and\nreporting",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Reporting flow\n1. Order manager stores\n    order entry\n    order status\n    client id\n2. this data is later used for reconciliation and\nreporting",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "AFBimUKbFgs_iQ01qocwA",
      "type": "text",
      "x": 2093.263893332887,
      "y": 1442.1916207626655,
      "width": 593.07958984375,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
