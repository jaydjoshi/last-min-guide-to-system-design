      "seed": 150091826,
      "version": 182,
      "versionNonce": 407431662,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783006000260,
      "link": null,
      "locked": false,
      "text": "Market data publisher\n1. Matching engine publishes matched order\n2. It is sent to publisher\n3. publisher sends data to real time market data system and\nhistorical order book",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Market data publisher\n1. Matching engine publishes matched order\n2. It is sent to publisher\n3. publisher sends data to real time market data system and\nhistorical order book",
      "autoResize": true,
      "lineHeight": 1.25
    },
