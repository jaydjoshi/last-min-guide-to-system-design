      "isDeleted": true,
      "boundElements": null,
      "updated": 1783006000260,
      "link": null,
      "locked": false,
      "text": "tables\n\n- Client\n- Stock\n- Order\n- Order Match\n- wallet\n- ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "tables\n\n- Client\n- Stock\n- Order\n- Order Match\n- wallet\n- ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wUMSrmPo1kQQA1Jh6mzX6",
      "type": "text",
      "x": 1409.5280442286653,
      "y": 1912.8840414309159,
      "width": 415.3797302246094,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZv",
      "roundness": null,
      "seed": 1719952626,
      "version": 204,
      "versionNonce": 124634866,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783006000260,
      "link": null,
      "locked": false,
      "text": "Datastructure OrderBook\n\nclass OrderBook{\n    private Book<Buy> buyBook;\n    private Book<Sell> sellBook;\n    private PriceLevel bestBid\n    private PriceLevel bestOffer;\n    private Map<OrderId, Order> orderMap;\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Datastructure OrderBook\n\nclass OrderBook{\n    private Book<Buy> buyBook;\n    private Book<Sell> sellBook;\n    private PriceLevel bestBid\n    private PriceLevel bestOffer;\n    private Map<OrderId, Order> orderMap;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "TGV9ApM6jD0s3ukfqnMLY",
      "type": "text",
      "x": 1904.4957324272566,
      "y": 1895.4584663137039,
      "width": 414.25970458984375,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bZw",
      "roundness": null,
      "seed": 77532082,
      "version": 232,
      "versionNonce": 1147918638,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783006000260,
      "link": null,
      "locked": false,
      "text": "class Book<Side>{\n    private Side side;\n    private Map<Price, PriceLevel> limitMap;\n}\n\nclass PriceLevel{\n    private Price limitPrice;\n    private Long totalVolume\n    private List<Order> orders;\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class Book<Side>{\n    private Side side;\n    private Map<Price, PriceLevel> limitMap;\n}\n\nclass PriceLevel{\n    private Price limitPrice;\n    private Long totalVolume\n    private List<Order> orders;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "2l8SNI5IonsFoNT8-YXwF",
      "type": "text",
      "x": 2944.5928751105785,
      "y": 1822.7685541307883,
