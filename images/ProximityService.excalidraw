    {
      "id": "6Xdm2bXFA-1lmADzdmXDT",
      "type": "text",
      "x": 920.5728759765625,
      "y": 933.5813369750977,
      "width": 610.5795288085938,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bW6",
      "roundness": null,
      "seed": 1062529714,
      "version": 403,
      "versionNonce": 1100727346,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1782923348421,
      "link": null,
      "locked": false,
      "text": "Pay in flow\n\n1. User -> api gateway ( auth, routing and ratelimiting, logging)\n2. Initiate Payment with payment service\n3. Persist payment event in db\n4. forward to payment adapter\n5. Persist payment order into DB\n6. forward to PSP\n7. card schema\n8 webhook to confirm payment\n8.a. update status in adapter and payment service\n9 update user wallet\n10 update double entry ledger",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pay in flow\n\n1. User -> api gateway ( auth, routing and ratelimiting, logging)\n2. Initiate Payment with payment service\n3. Persist payment event in db\n4. forward to payment adapter\n5. Persist payment order into DB\n6. forward to PSP\n7. card schema\n8 webhook to confirm payment\n8.a. update status in adapter and payment service\n9 update user wallet\n10 update double entry ledger",
      "autoResize": true,
      "lineHeight": 1.25
    },
