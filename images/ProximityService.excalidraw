    {
      "id": "svFB9hqLmnjp0qWm7u0nn",
      "type": "text",
      "x": 3090.2351004831976,
      "y": 237.72063057173068,
      "width": 808.4993896484375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
