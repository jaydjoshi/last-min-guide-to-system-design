    {
      "id": "R95XJn8bshbEi7YFKARmS",
      "type": "text",
      "x": 877.2237392665256,
      "y": 1293.1822418154977,
      "width": 503.9796142578125,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bYo",
      "roundness": null,
      "seed": 258342002,
      "version": 503,
      "versionNonce": 972605874,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783006000260,
      "link": null,
      "locked": false,
      "text": "Flow:\nCreate order \n\n1. Broker to Client gateway\n2. gateway to order manager\n    Risk check\n    wallet check\n    reserve funds\n3. Persist data for reporting ( Reporting flow)\n4. Order manager -> sequencer\n5. Sequencer to matching engine\n    engine matches orders,\n    if matched,\n        create to fills, executions, \n        buy and sell\n6. Order processor processes those individual order\n7. qrites back to sequencer\n8. data back to order manager.\n    persist data for reporting\n9. sends data back to client",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flow:\nCreate order \n\n1. Broker to Client gateway\n2. gateway to order manager\n    Risk check\n    wallet check\n    reserve funds\n3. Persist data for reporting ( Reporting flow)\n4. Order manager -> sequencer\n5. Sequencer to matching engine\n    engine matches orders,\n    if matched,\n        create to fills, executions, \n        buy and sell\n6. Order processor processes those individual order\n7. qrites back to sequencer\n8. data back to order manager.\n    persist data for reporting\n9. sends data back to client",
      "autoResize": true,
      "lineHeight": 1.25
    },
