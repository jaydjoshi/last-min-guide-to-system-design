    {
      "id": "yiaezqjch8hYrRxuPLDEX",
      "type": "text",
      "x": 1939.4378533695242,
      "y": 395.8267132829478,
      "width": 735.239501953125,
      "height": 650,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bXw",
      "roundness": null,
      "seed": 1747828722,
      "version": 815,
      "versionNonce": 819856562,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1782992039159,
      "link": null,
      "locked": false,
      "text": "Wallet cration Flow:\nuser to gateway : authenticate, rate limiting and logging, routing\n1. onboarding -> KYC\n2. onboarding complete -> craete wallet\n3. create card\n\n\nAdd money\n1. Initiate money in to the wallet with payment service\n2. PS calls Paymennt gate, gateway handles the tarnsfer via UPI, card etc\n3. And send a webhook to payment service\n4. publish an event \n\nCard spend\n1. bank -> card service : gets a webhook that money was spent\n\n\nMoney transfer\n1. user -> payment : initiate transfer\n2. validate\n3. tarnsaction\n    debit money from account 1\n    credit money to account 2\n    update double entry ledger\n    update balances in both wallets\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Wallet cration Flow:\nuser to gateway : authenticate, rate limiting and logging, routing\n1. onboarding -> KYC\n2. onboarding complete -> craete wallet\n3. create card\n\n\nAdd money\n1. Initiate money in to the wallet with payment service\n2. PS calls Paymennt gate, gateway handles the tarnsfer via UPI, card etc\n3. And send a webhook to payment service\n4. publish an event \n\nCard spend\n1. bank -> card service : gets a webhook that money was spent\n\n\nMoney transfer\n1. user -> payment : initiate transfer\n2. validate\n3. tarnsaction\n    debit money from account 1\n    credit money to account 2\n    update double entry ledger\n    update balances in both wallets\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
