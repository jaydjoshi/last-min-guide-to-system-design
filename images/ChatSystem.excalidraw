    {
      "id": "5dowklqdEheej06-Ovb21",
      "type": "text",
      "x": 615.441650390625,
      "y": 131.29705810546875,
      "width": 391.91583251953125,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
