    {
      "id": "WvuFxYrSb8MWWGr6S3yyO",
      "type": "text",
      "x": 998.7541699810977,
      "y": 1316.1449331040885,
      "width": 766.219482421875,
      "height": 950,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFQ",
      "roundness": null,
      "seed": 1520530990,
      "version": 791,
      "versionNonce": 1910507950,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782621641726,
      "link": null,
      "locked": false,
      "text": "Flow:\n\n1:1 chat:\nuser1 performs auth\nuser1 performs handshake with web socket manager \nweb socket manager assigns a ws server to user\nuser1 communicates with web socket server\nuser1 sends a message to user2:\n    websocketserver 1 adds message to kafka which gets writen to cassandra\n    user2 connected to ws2 ( known via manager)\n    ws2 reads message from the queue\n    user2 gets the message\n\n\ngroup chat\nuser1 performs auth\nuser1 performs handshake with web socket manager \nweb socket manager assigns a ws server to user\nuser1 communicates with web socket server\nuser1 sends a message to group1:\n    websocketserver 1 adds message to kafka which gets writen to cassandra\n    group manager gets all users info from the group ( group to users mapping)\n    ws2, 3 , 4 reads the message from queu ( via manager)\n    all users gets the messge\n \n\noffline 1:1\nuser1 performs auth\nuser1 performs handshake with web socket manager \nweb socket manager assigns a ws server to user\nuser1 communicates with web socket server\nuser1 sends a message to user2:\n    websocketserver 1 adds message to kafka which gets writen to cassandra\n    user2 connected to ws2 ( known via manager)\n    ws2 reads message from the queue\n    user2 is offline, so a push notification is sent\n    user2 gets the message when they are online via offline servers\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flow:\n\n1:1 chat:\nuser1 performs auth\nuser1 performs handshake with web socket manager \nweb socket manager assigns a ws server to user\nuser1 communicates with web socket server\nuser1 sends a message to user2:\n    websocketserver 1 adds message to kafka which gets writen to cassandra\n    user2 connected to ws2 ( known via manager)\n    ws2 reads message from the queue\n    user2 gets the message\n\n\ngroup chat\nuser1 performs auth\nuser1 performs handshake with web socket manager \nweb socket manager assigns a ws server to user\nuser1 communicates with web socket server\nuser1 sends a message to group1:\n    websocketserver 1 adds message to kafka which gets writen to cassandra\n    group manager gets all users info from the group ( group to users mapping)\n    ws2, 3 , 4 reads the message from queu ( via manager)\n    all users gets the messge\n \n\noffline 1:1\nuser1 performs auth\nuser1 performs handshake with web socket manager \nweb socket manager assigns a ws server to user\nuser1 communicates with web socket server\nuser1 sends a message to user2:\n    websocketserver 1 adds message to kafka which gets writen to cassandra\n    user2 connected to ws2 ( known via manager)\n    ws2 reads message from the queue\n    user2 is offline, so a push notification is sent\n    user2 gets the message when they are online via offline servers\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
