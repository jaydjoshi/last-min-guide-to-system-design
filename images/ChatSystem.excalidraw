      "link": null,
      "locked": false,
      "text": "user profile updates\nvia profile service\n\n\nattachments : similar behaviour attachment get written to S3",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "user profile updates\nvia profile service\n\n\nattachments : similar behaviour attachment get written to S3",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "g_UABx2srgsVKaWQS54Y3",
      "type": "text",
      "x": 2750.63948654079,
      "y": 245.98334172266004,
      "width": 1361.97900390625,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFi",
      "roundness": null,
      "seed": 1860025454,
      "version": 27,
      "versionNonce": 1860898542,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782622202005,
      "link": null,
      "locked": false,
      "text": "Modern chat systems use\nQUIC (Quick UDP Internet Connections) is a modern transport protocol originally developed by Google and now standardized by the IETF.\n\nThink of it as:\n\nTCP + TLS + HTTP/2\n        ↓\n      QUIC",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Modern chat systems use\nQUIC (Quick UDP Internet Connections) is a modern transport protocol originally developed by Google and now standardized by the IETF.\n\nThink of it as:\n\nTCP + TLS + HTTP/2\n        ↓\n      QUIC",
      "autoResize": true,
      "lineHeight": 1.25
    },
