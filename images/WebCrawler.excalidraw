    {
      "id": "Glh2JAvnLJL60P_bVC3aD",
      "type": "text",
      "x": 259.2544653805767,
      "y": 977.7855824126443,
      "width": 256.49981689453125,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7p",
      "roundness": null,
      "seed": 1539463218,
      "version": 183,
      "versionNonce": 1234786418,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782559994763,
      "link": null,
      "locked": false,
      "text": "Back of the envelope calc:\n\n1b web pages per month\n500 kb\n\n1 b * 500 kb\n10^9 * 500 kb = \n500 TB per month\n\n5 years\n500 Tb * 5 * 12\n= 500 * 60 TB\n= 30000 TB\n= 30 PB",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Back of the envelope calc:\n\n1b web pages per month\n500 kb\n\n1 b * 500 kb\n10^9 * 500 kb = \n500 TB per month\n\n5 years\n500 Tb * 5 * 12\n= 500 * 60 TB\n= 30000 TB\n= 30 PB",
      "autoResize": true,
      "lineHeight": 1.25
    },
