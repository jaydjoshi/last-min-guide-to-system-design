      "seed": 1104824754,
      "version": 505,
      "versionNonce": 1525810738,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1782561334416,
      "link": null,
      "locked": false,
      "text": "Questions:\n\n1. purpose\nfor indexing search engine\n\n2. scale?\n1b wed pages per month\n\n3. content ?\nHTML\n\n4. how does it work?\nGet set of URLs\nDownload and Get content from the URL, persist it\nGet URLs from the content and repeat\n\n\nFunctional req:\nWe want to build a web crawler that gets URL list \nand downloads the content and persists it\n\nNFR:\nScalability\nPoliteness\nRobustness\nPritity ordering\nExtensibility\nhigh throughput",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Questions:\n\n1. purpose\nfor indexing search engine\n\n2. scale?\n1b wed pages per month\n\n3. content ?\nHTML\n\n4. how does it work?\nGet set of URLs\nDownload and Get content from the URL, persist it\nGet URLs from the content and repeat\n\n\nFunctional req:\nWe want to build a web crawler that gets URL list \nand downloads the content and persists it\n\nNFR:\nScalability\nPoliteness\nRobustness\nPritity ordering\nExtensibility\nhigh throughput",
      "autoResize": true,
      "lineHeight": 1.25
    },
