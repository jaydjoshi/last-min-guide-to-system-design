    {
      "id": "jPxXbInfOj2fZzznxhxAc",
      "type": "text",
      "x": 258,
      "y": 232.5,
      "width": 509.439697265625,
      "height": 700,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
