    },
    {
      "id": "utILHuJtJ8xccfDmE2A7q",
      "type": "text",
      "x": 526.6021728515625,
      "y": 218.20703125,
      "width": 674.8795166015625,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b20",
      "roundness": null,
      "seed": 2047460119,
      "version": 363,
      "versionNonce": 675130647,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781601746512,
      "link": null,
      "locked": false,
      "text": "Questions:\n1. like tiny url? which converts URLs to short url and redirects them?\nyes\n2. Scale?\n100 M writes a day\n\nFunctional requirements:\n1. Convert long URL to short\n2. When short url received, redirect to long url\n\nNFR:\n1. low latency\n2. High availability\n3. non deterministic",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Questions:\n1. like tiny url? which converts URLs to short url and redirects them?\nyes\n2. Scale?\n100 M writes a day\n\nFunctional requirements:\n1. Convert long URL to short\n2. When short url received, redirect to long url\n\nNFR:\n1. low latency\n2. High availability\n3. non deterministic",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SxFlAYOg-7dKG23ADTtzf",
      "type": "text",
      "x": 1240.186767578125,
      "y": 241.98440551757812,
      "width": 444.43975830078125,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b21",
      "roundness": null,
      "seed": 1342186809,
      "version": 397,
      "versionNonce": 989562841,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781601991521,
      "link": null,
      "locked": false,
      "text": "Back of envelope calc\ntraffic:\n100 m writes a day\n100 * 10^6 / 10^5 seconds = 1000 rps writes\n100:1 read to write ratio\n\n1000*100 = 100,000 reads per seconds\n\nStorage:\n100 M * 365 * 10 years = \n356B records over 10 years time\n500 bytes per record\n365b * 500 = 2000 * 100 b\n= 200t = 200 Tb",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Back of envelope calc\ntraffic:\n100 m writes a day\n100 * 10^6 / 10^5 seconds = 1000 rps writes\n100:1 read to write ratio\n\n1000*100 = 100,000 reads per seconds\n\nStorage:\n100 M * 365 * 10 years = \n356B records over 10 years time\n500 bytes per record\n365b * 500 = 2000 * 100 b\n= 200t = 200 Tb",
      "autoResize": true,
      "lineHeight": 1.25
    },
