    },
    {
      "id": "l99y5brJ1Es5lF1QiJIP5",
      "type": "text",
      "x": 997.3320876692496,
      "y": 898.163749180495,
      "width": 665.1796264648438,
      "height": 1175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bes",
      "roundness": null,
      "seed": 632429772,
      "version": 967,
      "versionNonce": 1340177484,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783272358320,
      "link": null,
      "locked": false,
      "text": "Location svc :\nLocation captured at client and sent to server every 15 seconds\nDB : cassandra optmised for write\nAPI: \nPOST /api/v1/locations\n\nNavigation svc:\nGive shortest path from A to B\nObject storage : routing tiles\nAPI \nGET /api/v1navigations?\n\nCDN :\nserve static maps\neither\n- Convert lat, long and zoom level to geohash map tile\n- or introduce a service to configure lat, long and zoom to tile name\n\n\nData : \n\nRouting tile data:\ni/p raw dataset -> o/p routing tile\nran every few days/ months\n\nEach routing tile has\n- Graph Nodes\n- Edges\n- References to other tiles\n\nStore in object storage by geohash\n\nLocation data:\nused to :\n1. Update traffic\n2. Update routing tile ( some road is blocked, flooded etc)\n3. used to update map data\ncassandra ( cause write heavy)\nschema:\nuserId, timestamp, lat, long, driving_mode\n\nGeocoding db :\nstore places and its lat, long pair\n\nStatic map data:\nstored in CDN\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Location svc :\nLocation captured at client and sent to server every 15 seconds\nDB : cassandra optmised for write\nAPI: \nPOST /api/v1/locations\n\nNavigation svc:\nGive shortest path from A to B\nObject storage : routing tiles\nAPI \nGET /api/v1navigations?\n\nCDN :\nserve static maps\neither\n- Convert lat, long and zoom level to geohash map tile\n- or introduce a service to configure lat, long and zoom to tile name\n\n\nData : \n\nRouting tile data:\ni/p raw dataset -> o/p routing tile\nran every few days/ months\n\nEach routing tile has\n- Graph Nodes\n- Edges\n- References to other tiles\n\nStore in object storage by geohash\n\nLocation data:\nused to :\n1. Update traffic\n2. Update routing tile ( some road is blocked, flooded etc)\n3. used to update map data\ncassandra ( cause write heavy)\nschema:\nuserId, timestamp, lat, long, driving_mode\n\nGeocoding db :\nstore places and its lat, long pair\n\nStatic map data:\nstored in CDN\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
