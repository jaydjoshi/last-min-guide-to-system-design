    {
      "id": "sn6mxJSADk-GNYIXESWnp",
      "type": "text",
      "x": 1744.8260940219056,
      "y": 938.6408829278855,
      "width": 647.9795532226562,
      "height": 600,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bhv",
      "roundness": null,
      "seed": 1014378987,
      "version": 547,
      "versionNonce": 1305275493,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783770419766,
      "link": null,
      "locked": false,
      "text": "Events\nad-clicked.v1 ( adId, userId, timestamp, idempotencyKey, ip, region)\n\n\nDB tables:\nAd_CLick_Event\n\n\n\nAggregations:\n1. number of events in a min : Simple sliding window technique\nsum : yes\navg: yes\norder: \n\nstores in postgres\nDB tables:\nAd_Click_Event_Aggregation\nid, aggregationType, aggregationValue, from, to\n\nAPIs\n/agent-api/v1/ads/{adId}?from=?&to=?&filters=?\n/agent-api/v1/ads?top=100&filters=?\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Events\nad-clicked.v1 ( adId, userId, timestamp, idempotencyKey, ip, region)\n\n\nDB tables:\nAd_CLick_Event\n\n\n\nAggregations:\n1. number of events in a min : Simple sliding window technique\nsum : yes\navg: yes\norder: \n\nstores in postgres\nDB tables:\nAd_Click_Event_Aggregation\nid, aggregationType, aggregationValue, from, to\n\nAPIs\n/agent-api/v1/ads/{adId}?from=?&to=?&filters=?\n/agent-api/v1/ads?top=100&filters=?\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "HZzv2YXGsiMsiQXKE2s-j",
      "type": "line",
      "x": 2431.3527291638657,
      "y": 166.98471086818884,
      "width": 26.68067541145956,
      "height": 1837.5146553156574,
      "angle": 0,
      "strokeColor": "#1e1e1e",
