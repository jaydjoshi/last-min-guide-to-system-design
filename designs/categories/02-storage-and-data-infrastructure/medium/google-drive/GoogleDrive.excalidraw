      "isDeleted": false,
      "boundElements": null,
      "updated": 1782399948739,
      "link": null,
      "locked": false,
      "text": "APIs:\n\nUMS : API gateway : JWT based authentication and auth\n\nstorage-svc :\nPOST /api/v1/folders/ ( idempotency id)\nPUT /api/v1/folders/{folder-id}\nGET /api/v1/folders/\nGET /api/v1/folders/{folder-id}\n\nPOST /api/v1/folders/{folder-id}/files/\nGET /api/v1/folders/{folder-id}/files/{id}\nPATCH /api/v1/folders/{folder-id}/files/{id}\nGET /api/v1/folders/{folder-id}/files/{id}/downloads\n\n\n\nTables:\n\nUMS:\nUser\n\nMetadatadb:\nTables:\nFile : id, name, size, hash, location, audit fields, checksum\nFile_Version : id, file_id, version_number, audit fields, location\nFolder : id, name, size\nBlock: id, file_id, name, sequence, \n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "APIs:\n\nUMS : API gateway : JWT based authentication and auth\n\nstorage-svc :\nPOST /api/v1/folders/ ( idempotency id)\nPUT /api/v1/folders/{folder-id}\nGET /api/v1/folders/\nGET /api/v1/folders/{folder-id}\n\nPOST /api/v1/folders/{folder-id}/files/\nGET /api/v1/folders/{folder-id}/files/{id}\nPATCH /api/v1/folders/{folder-id}/files/{id}\nGET /api/v1/folders/{folder-id}/files/{id}/downloads\n\n\n\nTables:\n\nUMS:\nUser\n\nMetadatadb:\nTables:\nFile : id, name, size, hash, location, audit fields, checksum\nFile_Version : id, file_id, version_number, audit fields, location\nFolder : id, name, size\nBlock: id, file_id, name, sequence, \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
