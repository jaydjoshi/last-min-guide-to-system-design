  "elements": [
    {
      "id": "MNnPyVc9N70QoB1Jtwv0Y",
      "type": "text",
      "x": 560,
      "y": 130.5,
      "width": 336.22381591796875,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFm",
      "roundness": null,
      "seed": 440484270,
      "version": 29,
