    {
      "id": "Kj1he_iR-qQlfYvDOgXsZ",
      "type": "text",
      "x": 3386.8355725294014,
      "y": 693.7840114985916,
      "width": 429.959716796875,
      "height": 825,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
