    {
      "id": "JCLdt2QY3lKrpg9FqHx1d",
      "type": "text",
      "x": 6724.100138958431,
      "y": 2222.30479577418,
      "width": 1077.6591796875,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
