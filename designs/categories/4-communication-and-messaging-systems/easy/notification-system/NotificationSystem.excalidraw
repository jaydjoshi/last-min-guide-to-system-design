    {
      "id": "dC1wYSgnOBQ-ITNRWI3jn",
      "type": "text",
      "x": 1029.0058890571916,
      "y": 1826.4148928415702,
      "width": 591.759521484375,
      "height": 625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
