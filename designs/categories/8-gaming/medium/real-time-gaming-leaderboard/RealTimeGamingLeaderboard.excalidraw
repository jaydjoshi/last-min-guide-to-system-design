      "text": "Events and APIs\nmatch-completed.v1\n\n\n\n\n\nleaderboard-updated.v1\n\nGET api/v1/game/{id}/leaderboard?top=10\nGET api/v1/game/{id}/leaderboard/position/mine\nJWT : userId\n\nGET api/v1/user/profile\nGET api/v1/matches/\nGET api/v1/matches/{id}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Events and APIs\nmatch-completed.v1\n\n\n\n\n\nleaderboard-updated.v1\n\nGET api/v1/game/{id}/leaderboard?top=10\nGET api/v1/game/{id}/leaderboard/position/mine\nJWT : userId\n\nGET api/v1/user/profile\nGET api/v1/matches/\nGET api/v1/matches/{id}",
