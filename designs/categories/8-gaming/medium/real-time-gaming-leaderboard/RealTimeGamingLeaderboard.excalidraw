    {
      "id": "beZM9SXkaSRpQPl2NIVh9",
      "type": "text",
      "x": 1119.1715087890625,
      "y": 825.7390747070312,
      "width": 435.6396789550781,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
