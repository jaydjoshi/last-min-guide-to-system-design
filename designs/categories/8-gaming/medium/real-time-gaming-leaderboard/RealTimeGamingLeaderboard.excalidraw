      "index": "bih",
      "roundness": null,
      "seed": 405401547,
      "version": 367,
      "versionNonce": 640657573,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783774352336,
      "link": null,
      "locked": false,
      "text": "Flows:\n1. Match score and leaderboard\nWe get match scores in kafka\nmatch service maintians a copy of scores\nleaderboard svc gets the score and creates \nleaderboard for the tounament\n\n\n2. Get leaderboard\nuser queries leaderboard svc to view \n- top 10 positions\n- users position on leaderboard\n    with +4 and -4 positions\n- click on user and get match details",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flows:\n1. Match score and leaderboard\nWe get match scores in kafka\nmatch service maintians a copy of scores\nleaderboard svc gets the score and creates \nleaderboard for the tounament\n\n\n2. Get leaderboard\nuser queries leaderboard svc to view \n- top 10 positions\n- users position on leaderboard\n    with +4 and -4 positions\n- click on user and get match details",
      "autoResize": true,
      "lineHeight": 1.25
    },
