      "updated": 1783767958739,
      "link": null,
      "locked": false,
      "text": "data:\n\nLine protocal :\n\nmetricType, list of key, value pairs, value, timestamp\ncpuLoad, serviceId: 123, nodeId:345, 0.1, 1345698872",
