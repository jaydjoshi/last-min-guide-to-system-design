      "groupIds": [],
      "frameId": null,
      "index": "bir",
      "roundness": null,
      "seed": 1442060229,
      "version": 605,
      "versionNonce": 1205777451,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783775601062,
      "link": null,
      "locked": false,
      "text": "DB\n\nLeaderboard:\n\nAccess patterns\ntop 10\nscore for a user\n\noptions\nSQL : not optimal needs indexing\nNoSQL\nRedis\n\nRedis: sorted sets -> hash table + skip list\n\nhas 2 data structures:\nhash table: user to scores\nskip list : scres to users\n\nZADD user\nZINCRBY score\nZRANGE / ZRANGEREV : get top 10\nZRANK : get rank of a user\n\n\nNoSQL\n\nleaderboard\npk ( partition : game + tournament, ck : score desc or rank asc )\n\nuser_rank\npk ( partition: gaem+ tounament + user, rank)\n\nuser_matches\npk ( partition: gaem+ tounament + user, matchId)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DB\n\nLeaderboard:\n\nAccess patterns\ntop 10\nscore for a user\n\noptions\nSQL : not optimal needs indexing\nNoSQL\nRedis\n\nRedis: sorted sets -> hash table + skip list\n\nhas 2 data structures:\nhash table: user to scores\nskip list : scres to users\n\nZADD user\nZINCRBY score\nZRANGE / ZRANGEREV : get top 10\nZRANK : get rank of a user\n\n\nNoSQL\n\nleaderboard\npk ( partition : game + tournament, ck : score desc or rank asc )\n\nuser_rank\npk ( partition: gaem+ tounament + user, rank)\n\nuser_matches\npk ( partition: gaem+ tounament + user, matchId)",
      "autoResize": true,
      "lineHeight": 1.25
    },
