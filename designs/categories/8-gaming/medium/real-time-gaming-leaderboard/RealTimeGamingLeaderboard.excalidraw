    {
      "id": "4XCmdtiO_3blpsCBMOFvY",
      "type": "text",
      "x": 2319.9624177235833,
      "y": 230.75400345676312,
      "width": 627.8395385742188,
      "height": 875,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
