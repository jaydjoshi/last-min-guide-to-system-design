    {
      "id": "1Kvzgg9jCBRH9ivdYtZPN",
      "type": "text",
      "x": 1000.7442626953125,
      "y": 1009.4170532226562,
      "width": 479.21966552734375,
      "height": 625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "be7",
      "roundness": null,
      "seed": 1834213748,
      "version": 438,
      "versionNonce": 648318796,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783243033629,
      "link": null,
      "locked": false,
      "text": "Flow : \n1. User -> API gateway\n    Routing\n    Auth\n    Rate limiting\n\n2. usr -> APi servers\n    Friends\n    profile\n\n3. user -> location service\n    location gets updated\n    \n4. friend location service\n    gets friends from friends svc\n    gets an event of locaton update from friends\n    Redis :\n    storage\n    userId : lat, long, timestamp\n    100m * 20 bytes * 500 friends\n    = 10^6 * 10^3 kb\n    = 1 tb\n    \n    ws with user to send bi-directional comm\n    ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Flow : \n1. User -> API gateway\n    Routing\n    Auth\n    Rate limiting\n\n2. usr -> APi servers\n    Friends\n    profile\n\n3. user -> location service\n    location gets updated\n    \n4. friend location service\n    gets friends from friends svc\n    gets an event of locaton update from friends\n    Redis :\n    storage\n    userId : lat, long, timestamp\n    100m * 20 bytes * 500 friends\n    = 10^6 * 10^3 kb\n    = 1 tb\n    \n    ws with user to send bi-directional comm\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
