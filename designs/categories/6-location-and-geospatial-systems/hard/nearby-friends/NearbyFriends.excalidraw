    {
      "id": "EG9HuMnI6tZg2mvyJbObN",
      "type": "text",
      "x": 1920.206919375219,
      "y": 197.89608703396084,
      "width": 590.19970703125,
      "height": 625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "beD",
      "roundness": null,
      "seed": 2047797068,
      "version": 490,
      "versionNonce": 2098029940,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783253619761,
      "link": null,
      "locked": false,
      "text": "Availability:\n\nMulti region and multi AZ deployment : 99.9 to 99.99\nEKS : auto sclaing\nCB\ngraceful degradation\n\nDB : Location svc:\nwrite heavy, hence casandra\n\nfriends location svc: redis.\ncould we use Redis pub/sub instead of kafka + redis yes\n\nHow many redis servers?\n\nmemory\nNeed mapping of userId to friends userId\nuserId to lat, long and timestamp\n\ntraffic\n\n\nFor location store : Use RedisGeo -> GeoHash + Sorted Set\n\nIn raal world,use HTTP over websocket",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Availability:\n\nMulti region and multi AZ deployment : 99.9 to 99.99\nEKS : auto sclaing\nCB\ngraceful degradation\n\nDB : Location svc:\nwrite heavy, hence casandra\n\nfriends location svc: redis.\ncould we use Redis pub/sub instead of kafka + redis yes\n\nHow many redis servers?\n\nmemory\nNeed mapping of userId to friends userId\nuserId to lat, long and timestamp\n\ntraffic\n\n\nFor location store : Use RedisGeo -> GeoHash + Sorted Set\n\nIn raal world,use HTTP over websocket",
      "autoResize": true,
      "lineHeight": 1.25
    },
