    {
      "id": "vJWzcqExQ86ZNUkfdiCS0",
      "type": "text",
      "x": 1048,
      "y": 1044.5,
      "width": 574.7796020507812,
      "height": 400,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bJG",
      "roundness": null,
      "seed": 431878766,
      "version": 694,
      "versionNonce": 39930226,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1782701641287,
      "link": null,
      "locked": false,
      "text": "Producer : produces a message\nConsumer : consumes a message\nTopic : Categorizes a message like order, payment etc\noperate in FIFO\nPartition : Split a topic by partitioning data\n    by hash\n    by key ranges\nBroker : server that hold partitions\nConsumer group : group of consumers for a particular topic\noffset : position of message in a partition\nStorages : \n    Data storage : Messages\n    State storage : state of consumers state\n    metadata storage : topic info, \nService discovery : which brokers are alive, leader election.\nlike zookeeper or raft",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Producer : produces a message\nConsumer : consumes a message\nTopic : Categorizes a message like order, payment etc\noperate in FIFO\nPartition : Split a topic by partitioning data\n    by hash\n    by key ranges\nBroker : server that hold partitions\nConsumer group : group of consumers for a particular topic\noffset : position of message in a partition\nStorages : \n    Data storage : Messages\n    State storage : state of consumers state\n    metadata storage : topic info, \nService discovery : which brokers are alive, leader election.\nlike zookeeper or raft",
      "autoResize": true,
      "lineHeight": 1.25
    },
