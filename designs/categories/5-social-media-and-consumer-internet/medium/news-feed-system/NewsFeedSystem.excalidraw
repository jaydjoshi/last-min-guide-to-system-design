      "isDeleted": true,
      "boundElements": null,
      "updated": 1782701641288,
      "link": null,
      "locked": false,
      "text": "Producer : send msg with ACK=0, if broker reads message but crash, msg may be lost\nConsumer : reads message and commits the offset, if consumer crashes, msg lost\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Producer : send msg with ACK=0, if broker reads message but crash, msg may be lost\nConsumer : reads message and commits the offset, if consumer crashes, msg lost\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
