      "seed": 1632372594,
      "version": 406,
      "versionNonce": 1345325038,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782701641288,
      "link": null,
      "locked": false,
      "text": "Producer : send msg with ACK=1 or ACK=ALL, if broker commits after message is stored in data storage (WAL)\nConsumer : reads message, consumes and later, commits the offset, if consumer crashes, msg is consumed\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Producer : send msg with ACK=1 or ACK=ALL, if broker commits after message is stored in data storage (WAL)\nConsumer : reads message, consumes and later, commits the offset, if consumer crashes, msg is consumed\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
