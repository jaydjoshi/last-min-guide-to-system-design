    {
      "id": "qAzmzybuU2cMQnloaJzpD",
      "type": "text",
      "x": 1934.035010538938,
      "y": 304.43410322839543,
      "width": 351.0197448730469,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
