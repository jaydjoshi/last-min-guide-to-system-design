    },
    {
      "id": "951VhpRX4xxrHry5WmBVh",
      "type": "text",
      "x": 6614.318457182413,
      "y": 269.22242908829287,
      "width": 729.53955078125,
      "height": 575,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bN0",
      "roundness": null,
      "seed": 1890026734,
      "version": 596,
      "versionNonce": 782838254,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1782701641288,
      "link": null,
      "locked": false,
      "text": "10. Replication ( & ISR)\nReplication factor : stored in metadata storage\nhow many servers should replicate the data\n\nIs sync replication ( ISR) : how many servers should ACK before leader\nAcknowledges the commit to producer\nReplica are in sync with leaders\n\nACK = 0\nNo other server/ leader must ACK that data is stored in its data storage\nlow latency, weakest message durability\n\n\nACK = 1\n1 leader must ACK that data is stored in its data storage\n\n\nACK = ALL\nAll other servers must ACK that data is stored in its data storage\nhigh latency, strongest message durability\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "10. Replication ( & ISR)\nReplication factor : stored in metadata storage\nhow many servers should replicate the data\n\nIs sync replication ( ISR) : how many servers should ACK before leader\nAcknowledges the commit to producer\nReplica are in sync with leaders\n\nACK = 0\nNo other server/ leader must ACK that data is stored in its data storage\nlow latency, weakest message durability\n\n\nACK = 1\n1 leader must ACK that data is stored in its data storage\n\n\nACK = ALL\nAll other servers must ACK that data is stored in its data storage\nhigh latency, strongest message durability\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WJlbmjhVp-KsSfdvH5a9o",
      "type": "line",
      "x": 6514.367860465938,
      "y": 265.0276422491894,
      "width": 85.88839836304123,
      "height": 2019.5342965649256,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
