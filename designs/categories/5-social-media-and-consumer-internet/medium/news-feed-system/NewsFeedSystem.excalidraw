      "link": null,
      "locked": false,
      "text": "One partition data is never consumed by multiple consumers in same consumer group\nWhy?\nTo ensure ordering\n\nMultiple consumers from different consumer groups can consume data from one partition\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One partition data is never consumed by multiple consumers in same consumer group\nWhy?\nTo ensure ordering\n\nMultiple consumers from different consumer groups can consume data from one partition\n",
      "autoResize": true,
      "lineHeight": 1.25
